HOST_BIND_ADDR=127.0.0.1
HOST_PORT=4310
APP_DATA_HOST_DIR=./data
MEDIA_HOST_DIR=./library
# For a Windows or NAS/SMB share, use a path your Docker host can read.
# Example local folder: MEDIA_HOST_DIR=./library
# Example network share: MEDIA_HOST_DIR=//nas-host/share/media
# For Docker-native SMB mounting, copy compose.nas.yaml and set:
# NAS_SHARE=//nas-host/share
# NAS_MEDIA_DISPLAY_PATH=//nas-host/share/media
# NAS_MEDIA_CONTAINER_PATH=/media/library
# NAS_SMB_VERSION=3.0
# NAS_USERNAME=YOUR_NAS_USER
# NAS_PASSWORD=YOUR_NAS_PASSWORD
PORT=4300
APP_NAME=Orbital Library
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=
APP_OPEN_SIGNUP=0
APP_ENABLE_DEMO_SEED=0
APP_COOKIE_SECURE=0
APP_ENABLE_HSTS=0
APP_TRUST_PROXY=0
APP_DATA_DIR=/app/data
APP_MEDIA_ROOT_LABEL=Library
